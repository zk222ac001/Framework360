generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sector {
  FINANCE
  INSURANCE
  BANKING
  HEALTHCARE
  PHARMA
  UTILITIES
  WATER
  TRANSPORT
  LOGISTICS
  IT
  TELECOM
  MANUFACTURING
  RETAIL
  ENERGY
  PUBLIC
  EDUCATION
  OTHER
}

enum Framework {
  NIS2
  DORA
  ISO27001
  GDPR
  SOC2
  CIS18
  NIST_CSF
}

enum UserRole {
  CUSTOMER_ADMIN
  COMPLIANCE_MANAGER
  EVIDENCE_CONTRIBUTOR
  AUDITOR
  PLATFORM_ADMIN
}

enum AuthProvider {
  LOCAL
  AZURE_AD
  GOOGLE
  OKTA
}

enum InvitationType {
  INVITE
  PASSWORD_RESET
}

enum ControlStatus {
  NOT_STARTED
  IN_PROGRESS
  IMPLEMENTED
  NOT_APPLICABLE
}

enum ControlMaturity {
  AD_HOC
  REPEATABLE
  DEFINED
  MANAGED
  OPTIMIZED
}

enum EvidenceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  COMPANY_CREATED
  COMPANY_UPDATED
  CONTROL_UPDATED
  EVIDENCE_UPLOADED
  EVIDENCE_APPROVED
  EVIDENCE_REJECTED
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  REPORT_GENERATED
}

enum SsoProvider {
  AZURE_AD
  GOOGLE
  OKTA
}

enum SsoDomainStatus {
  PENDING
  VERIFIED
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED_RISK
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id                  String             @id @default(cuid())
  name                String
  cvr                 String?            @unique
  sector              Sector?
  country             String?
  address             String?
  subscriptionPlan    String?
  subscriptionStatus  String?
  subscriptionRenewal DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  users               User[]
  frameworks          CompanyFramework[]
  controls            Control[]
  evidence            Evidence[]
  tasks               Task[]
  vendors             Vendor[]
  systems             System[]
  businessProcesses   BusinessProcess[]
  dependencies        Dependency[]
  auditFindings       AuditFinding[]
  campaigns           EvidenceCampaign[]
  ssoDomains          SsoDomain[]
  demoRequests        DemoRequest[]
}

model CompanyFramework {
  id        String    @id @default(cuid())
  companyId String
  framework Framework
  enabled   Boolean   @default(true)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, framework])
}

model User {
  id                    String         @id @default(cuid())
  firstName             String
  lastName              String
  email                 String         @unique
  password              String?
  role                  UserRole       @default(CUSTOMER_ADMIN)
  isActive              Boolean        @default(true)
  mustChangePassword    Boolean        @default(false)
  onboardingCompleted   Boolean        @default(false)
  authProvider          AuthProvider   @default(LOCAL)
  providerId            String?
  lastLogin             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  companyId             String?
  company               Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  evidence              Evidence[]
  tasks                 Task[]
  auditLogs             AuditLog[]
  invitations           Invitation[]
  reports               Report[]
  comments              Comment[]
  ssoDomainsVerified    SsoDomain[]    @relation("SsoDomainVerifiedBy")
  auditFindingsOwned    AuditFinding[] @relation("FindingOwner")
  campaignAssignments   CampaignAssignment[]
  approvalRequests      ApprovalRequest[] @relation("ApprovalRequester")
  approvalDecisions     ApprovalRequest[] @relation("ApprovalApprover")
  activatedDemoRequests DemoRequest[]  @relation("DemoRequestCreatedUser")
}

model Invitation {
  id         String         @id @default(cuid())
  email      String?
  type       InvitationType @default(INVITE)
  secretHash String         @unique
  role       UserRole?
  companyId  String?
  userId     String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime       @default(now())
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Control {
  id                 String           @id @default(cuid())
  companyId          String
  framework          Framework
  controlId          String
  title              String
  description        String?
  status             ControlStatus    @default(NOT_STARTED)
  maturity           ControlMaturity?
  owner              String?
  dueDate            DateTime?
  riskLevel          RiskLevel?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  evidence           Evidence[]
  tasks              Task[]
  auditFindings      AuditFinding[]

  @@unique([companyId, framework, controlId])
}

model Evidence {
  id          String         @id @default(cuid())
  companyId   String
  controlId   String?
  uploadedById String?
  title       String
  description String?
  filePath    String?
  fileType    String?
  fileSize    Int?
  status      EvidenceStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control     Control?       @relation(fields: [controlId], references: [id], onDelete: SetNull)
  uploadedBy  User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  comments    Comment[]
  approvalRequests ApprovalRequest[]
}

model Task {
  id          String       @id @default(cuid())
  companyId   String
  controlId   String?
  assignedToId String?
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control     Control?     @relation(fields: [controlId], references: [id], onDelete: SetNull)
  assignedTo  User?        @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Report {
  id        String   @id @default(cuid())
  companyId String
  createdById String?
  title     String
  type      String
  filePath  String?
  createdAt DateTime @default(now())
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model Comment {
  id          String   @id @default(cuid())
  evidenceId  String
  userId      String?
  body        String
  createdAt   DateTime @default(now())
  evidence    Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SsoDomain {
  id           String          @id @default(cuid())
  companyId    String
  provider     SsoProvider
  domain       String          @unique
  status       SsoDomainStatus @default(PENDING)
  verifiedAt   DateTime?
  verifiedById String?
  createdAt    DateTime        @default(now())
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  verifiedBy   User?           @relation("SsoDomainVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
}

model Vendor {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  service     String?
  riskLevel   RiskLevel?
  owner       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dependencies Dependency[]
}

model System {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  owner       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dependencies Dependency[]
}

model BusinessProcess {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  owner       String?
  criticality RiskLevel?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dependencies Dependency[]
}

model Dependency {
  id                String           @id @default(cuid())
  companyId          String
  vendorId           String?
  systemId           String?
  businessProcessId  String?
  dependencyType     String
  description        String?
  riskLevel          RiskLevel?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor             Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  system             System?          @relation(fields: [systemId], references: [id], onDelete: SetNull)
  businessProcess    BusinessProcess? @relation(fields: [businessProcessId], references: [id], onDelete: SetNull)
}

model AuditFinding {
  id              String          @id @default(cuid())
  companyId       String
  controlId       String?
  ownerId         String?
  title           String
  description     String?
  severity        FindingSeverity @default(MEDIUM)
  status          FindingStatus   @default(OPEN)
  dueDate         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control         Control?        @relation(fields: [controlId], references: [id], onDelete: SetNull)
  owner           User?           @relation("FindingOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model EvidenceCampaign {
  id          String               @id @default(cuid())
  companyId   String
  title       String
  description String?
  status      CampaignStatus       @default(DRAFT)
  dueDate     DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments CampaignAssignment[]
}

model CampaignAssignment {
  id             String           @id @default(cuid())
  campaignId     String
  assigneeId     String?
  controlId      String?
  status         EvidenceStatus   @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  campaign       EvidenceCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignee       User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  evidenceId  String
  requestedById String?
  approverId  String?
  status      ApprovalStatus @default(PENDING)
  comment     String?
  decidedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  evidence    Evidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  requestedBy User?          @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approver    User?          @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)
}

model DemoRequest {
  id            Int      @id @default(autoincrement())
  email         String
  firstName     String
  lastName      String
  companyName   String
  jobTitle      String?
  country       String?
  status        String   @default("PENDING")
  companyId     String?
  createdUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdUser User?    @relation("DemoRequestCreatedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  toEmail   String
  type      String
  subject   String
  sentAt    DateTime @default(now())
}
