NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@db:5432/framework360
JWT_SECRET=replace_with_long_random_secret
CORS_ORIGIN=https://your-domain.com
APP_BASE_URL=https://your-domain.com
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace_me

# Optional SMTP settings for automatic account activation emails.
# If these are not configured, activation still succeeds and email sending is skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
