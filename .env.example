# Local Docker development environment.
# Copy this file to .env and replace the Stripe placeholders with test-mode values.

STRIPE_SECRET_KEY=sk_test_replace_me
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Use recurring Stripe Price IDs. These must start with price_, not prod_.
STRIPE_STARTER_PRICE_ID=price_replace_starter
STRIPE_PROFESSIONAL_PRICE_ID=price_replace_professional
STRIPE_ENTERPRISE_PRICE_ID=price_replace_enterprise
